# EaseCation User Center MCP Server
#
# 本模板默认面向真实后端联调。
# 如果管理员态/用户态分别接不同后端，可使用 EC_ADMIN_API_BASE_URL 与 EC_USER_API_BASE_URL 覆盖。
EC_API_BASE_URL=https://ucapi.easecation.net

# 是否启用管理员态与用户态工具。
EC_ENABLE_ADMIN_TOOLS=true
EC_ENABLE_USER_TOOLS=true

# 管理员 access token。
EC_ADMIN_JWT_TOKEN=

# 管理员 refresh token。配置后，MCP 会在 access token 失效时自动刷新。
EC_ADMIN_REFRESH_TOKEN=

# 用户 access token。
EC_USER_JWT_TOKEN=

# 用户 refresh token。配置后，MCP 会在 access token 失效时自动刷新。
EC_USER_REFRESH_TOKEN=

# API 超时（毫秒）
EC_API_TIMEOUT=30000

# MCP transport:
# - stdio: 适合 Claude Desktop / Codex / Cursor 等本地客户端
# - streamable-http: 适合远程或浏览器 MCP client
MCP_TRANSPORT=stdio

# 仅在 MCP_TRANSPORT=streamable-http 时使用
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3100
MCP_HTTP_PATH=/mcp
# 远程部署时建议配置。启用后，POST /mcp 需要 Authorization: Bearer <token>
MCP_HTTP_BEARER_TOKEN=
